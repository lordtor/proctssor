{
  "streams": [
    {
      "name": "WORKFLOW_CMD",
      "subjects": [
        "wf.cmd.>"
      ],
      "description": "WorkQueue stream for commands to workflow services",
      "retention": "workqueue",
      "max_bytes": 1073741824,
      "max_age": 3600,
      "storage": "file",
      "replicas": 1,
      "duplicate_window": 30000000000,
      "sealed": false,
      "allow_rollup_hdrs": false,
      "allow_direct": true,
      "discard": "old",
      "max_consumers": 10,
      "max_msg_size": 8388608,
      "compression": "none"
    },
    {
      "name": "WORKFLOW_RESP",
      "subjects": [
        "wf.resp.>"
      ],
      "description": "Interest-based stream for service responses",
      "retention": "interest",
      "max_bytes": 536870912,
      "max_age": 1800,
      "storage": "file",
      "replicas": 1,
      "duplicate_window": 60000000000,
      "sealed": false,
      "allow_rollup_hdrs": false,
      "allow_direct": true,
      "discard": "old",
      "max_consumers": 50,
      "max_msg_size": 4194304,
      "compression": "none"
    },
    {
      "name": "WORKFLOW_EVT",
      "subjects": [
        "wf.evt.>"
      ],
      "description": "Limits retention stream for events and audit trail",
      "retention": "limits",
      "max_bytes": 2147483648,
      "max_age": 604800,
      "storage": "file",
      "replicas": 1,
      "duplicate_window": 120000000000,
      "sealed": false,
      "allow_rollup_hdrs": true,
      "allow_direct": true,
      "discard": "old",
      "max_consumers": 100,
      "max_msg_size": 8388608,
      "compression": "none"
    }
  ],
  "consumers": [
    {
      "stream_name": "WORKFLOW_CMD",
      "name": "workflow-engine",
      "description": "Consumer for workflow engine command processing",
      "filter_subject": "wf.cmd.>",
      "delivery_subject": "wf.cmd.delivered",
      "deliver_policy": "new",
      "ack_policy": "explicit",
      "ack_wait": 300000000000,
      "max_deliver": 3,
      "max_ack_pending": 100,
      "replay_policy": "instant"
    },
    {
      "stream_name": "WORKFLOW_EVT",
      "name": "audit-consumer",
      "description": "Consumer for audit event logging",
      "filter_subject": "wf.evt.audit.>",
      "delivery_subject": "wf.evt.audit.delivered",
      "deliver_policy": "new",
      "ack_policy": "explicit",
      "ack_wait": 60000000000,
      "max_deliver": 5,
      "max_ack_pending": 1000,
      "replay_policy": "instant"
    }
  ]
}
