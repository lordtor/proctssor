  const metrics = data.metrics || {};
  const httpReqs = metrics.http_reqs || { count: 0 };
  const httpReqFailed = metrics.http_req_failed || { rate: 0, count: 0 };
  const httpReqDuration = metrics.http_req_duration || {};
  
  return `
