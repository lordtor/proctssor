# BPMN Workflow Platform - .gitignore

# =============================================================================
# Go
# =============================================================================
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.sum

# Go build output
/bin/
/build/
/dist/
/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment
.env
.env.local
.env.*.local

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
.next/
.nuxt/
output/

# NPM cache
.npm

# Yarn cache
.yarn

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Database
# =============================================================================
*.sql.gz
*.db
*.sqlite

# =============================================================================
# Logs
# =============================================================================
logs
*.log
*.pid
*.seed
*.pid.lock

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Misc
# =============================================================================
*.tmp
*.temp
coverage/
.cache/
